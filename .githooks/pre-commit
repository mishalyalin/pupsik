#!/usr/bin/env bash
# pre-commit hook for pupsik.
#
# Runs the paranoid privacy scan against the staged tree (tracked + untracked
# files git would see) BEFORE allowing the commit. The remote CI runs the
# same scan; this hook catches the same leak class one step earlier, so a
# bad commit never lands on a feature branch in the first place.
#
# Install:
#   bash scripts/install-git-hooks.sh
#
# Bypass (emergency, do not abuse):
#   PUPSIK_SKIP_PRIVACY_CHECK=1 git commit ...
#
# Why pre-commit, not pre-push:
#   Pre-push catches the leak before it reaches the remote, but the SHA
#   exists locally; if your editor / CI / reviewer caches the work-tree
#   diff, the bad bytes have already escaped your hands. Pre-commit
#   catches it before the SHA is even minted.

set -euo pipefail

if [ "${PUPSIK_SKIP_PRIVACY_CHECK:-0}" = "1" ]; then
  printf "\033[1;33m[pre-commit] PUPSIK_SKIP_PRIVACY_CHECK=1 set, skipping privacy scan.\033[0m\n" >&2
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CHECK_SCRIPT="$ROOT/.github/scripts/privacy-check.sh"

if [ ! -x "$CHECK_SCRIPT" ] && [ ! -f "$CHECK_SCRIPT" ]; then
  # Repo without the check script - nothing to enforce. Allow the commit.
  exit 0
fi

# --include-untracked because the leak class we are catching is exactly the
# "I just added a file with --include-untracked-blind contents" case. The
# default tracked-only mode would miss it.
if ! bash "$CHECK_SCRIPT" --include-untracked >/dev/null 2>&1; then
  # Rerun verbose so the user sees which pass and which file failed.
  printf "\033[1;31m[pre-commit] privacy-check FAILED. Output:\033[0m\n\n" >&2
  bash "$CHECK_SCRIPT" --include-untracked >&2 || true
  printf "\n\033[1;31m[pre-commit] commit aborted.\033[0m " >&2
  printf "Bypass with PUPSIK_SKIP_PRIVACY_CHECK=1 git commit ...\n" >&2
  exit 1
fi

exit 0
