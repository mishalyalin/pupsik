# Private privacy patterns - copy to private-patterns.env (gitignored) and fill in.
#
# This file is a TEMPLATE. The real patterns must NEVER be committed to git.
# privacy-check.sh sources `private-patterns.env` at runtime if present.
# CI uses GitHub Actions secrets with the same variable names, injected as env.
#
# All variables are optional. If unset, the corresponding pass either falls
# back to a public-safe minimum (Pass 1: byline only; Pass 4: format-only
# registry IDs) or is SKIPPED with a yellow warning (Passes 2, 5, 6).

# Pass 1 — full names of people in your network (suppliers, family, investors).
# Public fallback covers only the maintainer byline. Set this to extend.
# Format: extended regex, parenthesised alternation.
# Example: NAME_PATTERN_PRIVATE='(\bAlice[[:space:]]+Smith\b|\bBob[[:space:]]+Lee\b)'
NAME_PATTERN_PRIVATE=

# Pass 2 — domains of real email addresses (your work + supplier domains).
# Pattern is concatenated as: \b[A-Za-z0-9._%+-]+@<DOMAINS_PATTERN>\b
# Skip pass 2 if unset.
# Example: EMAIL_DOMAINS_PRIVATE='(yourcompany\.com|supplier1\.com|supplier2\.io)'
EMAIL_DOMAINS_PRIVATE=

# Pass 4 — specific identifiers (VAT, EIN, KVK, employee ID, etc.).
# Public fallback: format-only checks (any KVK 8-digit, NL VAT pattern, etc.)
# without specific instances. Set this to add the specific numbers.
# Example: REGISTRY_IDS_PRIVATE='(\b12345678\b|\bMY-VAT-12345\b)'
REGISTRY_IDS_PRIVATE=

# Pass 5 — specific home/office addresses.
# Skip if unset. Otherwise extended regex.
# Example: ADDRESSES_PRIVATE='(123[[:space:]]+Main[[:space:]]+St|EC2A[[:space:]]?4NE)'
ADDRESSES_PRIVATE=

# Pass 6 — business / project / supplier names.
# Skip if unset. Otherwise extended regex with word boundaries.
# Example: BUSINESSES_PRIVATE='(\bAcmeCorp\b|\bVendor[[:space:]]+X\b)'
BUSINESSES_PRIVATE=
