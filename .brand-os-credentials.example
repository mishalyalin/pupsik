# Brand OS API credentials - copy to ~/.brand-os-credentials and chmod 600.
#
# This file is the optional API-mode configuration for tools/brand_os.py.
# When all three keys are set, the helper hits your server-side Brand OS over
# HTTPS so every session (Claude, designer, marketer, copywriter) pulls from
# the same canonical canon. Without this file (or env vars), the helper falls
# back to a local Brand OS clone if one is detected.
#
# NEVER commit ~/.brand-os-credentials to git. The pupsik .gitignore covers
# the common filenames; if you put it elsewhere, add that path to your .git-
# ignore yourself.

BRAND_OS_API_URL=https://your-brain-host.example.com
BRAND_OS_API_USER=your-user
BRAND_OS_API_PASS=replace-with-real-secret

# Optional: request timeout in seconds (default 15).
# BRAND_OS_API_TIMEOUT=15
